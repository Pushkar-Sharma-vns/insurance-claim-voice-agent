# Copy to .env and fill in. Never commit .env.
VAPI_SECRET=pick-a-long-random-string      # shared secret; set same value in VAPI server.secret
AIRTABLE_TOKEN=pat_xxx                      # Airtable personal access token
AIRTABLE_BASE_ID=app_xxx                    # Airtable base id
CUSTOMERS_TABLE=Customers
INTERACTIONS_TABLE=Interactions
GEMINI_API_KEY=                             # Phase 2 only
VAPI_PRIVATE_KEY=                           # Phase 2 only: calling VAPI's API (poll structured outputs)
# Public key, assistant id, phone number live in the VAPI dashboard — not needed here.
